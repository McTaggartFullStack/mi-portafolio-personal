FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=8080

# Dependencias (usa lockfile para builds reproducibles)
COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force

# Copiar código fuente y todos los archivos estáticos (HTML, JS, img, etc)
COPY . ./

# Usuario no-root
USER node

ENV PORT=8080
EXPOSE 8080

CMD ["node", "backend/floria/server.js"]
