# Backend environment variables
NODE_ENV=development
PORT=8080

# ========================================
# SUNNY IA ASSISTANT (Independent service)
# ========================================
SUNNY_PORT=4000
SUNNY_CORS_ORIGIN=*
SUNNY_MAX_TOKENS=1024
SUNNY_TEMPERATURE=0.7
SUNNY_TIMEOUT_MS=10000
SUNNY_RETRY_ATTEMPTS=2

# Google Gemini API - Primary IA Provider
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-1.5-flash

# OpenAI API - Alternative provider (optional, for future use)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4-turbo

# Logging
LOG_LEVEL=info
VERBOSE=false

# ========================================
# LEGACY (Keep for backward compatibility)
# ========================================

# Gemini API key (deprecated, use GOOGLE_GEMINI_API_KEY)
GEMINI_API_KEY=

# Google reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Optional
SENTRY_DSN=
